# ─────────────────────────────────────────
# APP-GD-OS — Variables de entorno
# Copiar a .env y completar con valores reales
# ─────────────────────────────────────────

# Servidor
PORT=3000
NODE_ENV=development

# PostgreSQL (apunta al servicio "db" de docker-compose en local)
DATABASE_URL=postgresql://postgres:password@db:5432/app_gd_os

# JWT
JWT_SECRET=reemplaza_con_secreto_muy_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# Cloudinary (subida de fotos de instalación)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# OpenAI (cotizaciones automáticas vía IA)
OPENAI_API_KEY=sk-...

# WhatsApp Business API (Meta)
WHATSAPP_TOKEN=EAAxxxxx
WHATSAPP_VERIFY_TOKEN=token_verificacion_webhook
WHATSAPP_PHONE_ID=1234567890

# Secret operativo para rotar credenciales demo vía POST /auth/reset-demo
# (header: x-admin-secret). Generar con: openssl rand -hex 32
ADMIN_SECRET=cambia_esto_por_un_secreto_largo_aleatorio

# ─────────────────────────────────────────
# Credenciales demo (rotables vía POST /auth/reset-demo)
# Estos son los valores iniciales del seed. En producción ROTARLOS antes
# de cualquier presentación pública usando el endpoint protegido.
# ─────────────────────────────────────────
DEMO_ADMIN_EMAIL=admin@globaldesign.cl
DEMO_ADMIN_PASSWORD=<rotar_con_reset-demo>
DEMO_INSTALADOR_EMAIL=roberto@globaldesign.cl
DEMO_INSTALADOR_PASSWORD=<rotar_con_reset-demo>
